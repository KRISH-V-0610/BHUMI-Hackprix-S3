# ── Secrets — NEVER commit these ──────────────────────────────
.env
*.key
private_key.json
nrsc-*.json
bhumi-ee*.json
*-service-account*.json
# Belt-and-suspenders: any GCP service-account key in the repo root
*.iam.gserviceaccount.com.json
# Allow the example
!.env.example

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# ── Node / frontend ───────────────────────────────────────────
node_modules/
dist/
.vite/
*.local

# ── Generated data (large / regenerable) ──────────────────────
# Keep sample fixtures, ignore the heavy real outputs if desired
data/*.tif
data/*.tiff

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

