# Bhumi web frontend env. Copy to `.env` and adjust.

# Base URL for the Python/FastAPI backend. In dev, "/api" is proxied to :8000 (see vite.config.js).
VITE_API_BASE=/api

# Mock mode: when true, all endpoints read bundled sample JSON from /public/data instead of the API.
# Great for building/demoing without the backend running. Set to false for live mode.
VITE_USE_MOCK=true
