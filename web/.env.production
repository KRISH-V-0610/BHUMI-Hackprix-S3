# Production build config (used by `npm run build`).
# 👉 Set VITE_API_BASE to your deployed Render backend URL (NO trailing slash).
#    If you named the Render service "bhumi-api", the URL is https://bhumi-api.onrender.com
#    You can also override this in your frontend host's (Vercel/Netlify/Render) env settings.
VITE_API_BASE=https://bhumi-api-5uvw.onrender.com
VITE_USE_MOCK=false
