# ── Sarvam AI ─────────────────────────────────────────────────
# Get yours at https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Earth Engine (service account) ─────────────────────
# Service account email and path to its JSON key file.
EE_SERVICE_ACCOUNT=earth-engine-sa@your-project.iam.gserviceaccount.com
EE_PRIVATE_KEY_FILE=your-service-account.json
EE_PROJECT=your-gcp-project-id

# ── MongoDB ───────────────────────────────────────────────────
# Local default, or a MongoDB Atlas SRV string for a hosted demo.
# Backend falls back to data/*.json automatically if Mongo is unreachable.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<cluster>
MONGODB_DB=bhumi

# ── Backend ───────────────────────────────────────────────────
# Comma-separated origins allowed to call the API (the frontend dev server)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
